		"vite": "^7.3.5",
		"vite-plugin-wasm": "^3.6.0"
	},
	"dependencies": {
		"@bw/api": "workspace:*",
		"@bw/data": "workspace:*",
		"@bw/schema": "workspace:*",
		"@bw/ui": "workspace:*",
		"arctic": "^3.7.0",
		"jose": "^6.2.3"
